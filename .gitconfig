[init]
  defaultBranch = main
[http]
  cookiefile = ~/.gitcookies
[include]
  path = ~/.gitconfig_local
[core]
  pager = less -S
  editor = vim
  autocrlf = input
  commitGraph = true
  fsmonitor = true
  untrackedCache = true
  quotepath = false
  ignorecase = false
  attributesfile = ~/.gitattributes
  excludesfile = ~/dotfiles/.gitignore_global
[fetch]
  parallel = 0
[pull]
  rebase = true
[push]
  default = simple
  autoSetupRemote = true
  useForceIfIncludes = true
[diff]
  algorithm = histogram
  compactionHeuristic = true
  renameLimit = 9999
[merge]
  tool = vimdiff
  keepBackup = false
[mergetool]
  keepBackup = false
[diff "image"]
  textconv = stat -c %s
[interactive]
  diffFilter = diff-highlight
[pager]
  diff = diff-highlight | less
  show = diff-highlight | less
  log  = diff-highlight | less
[column]
  ui = auto
[branch]
  sort = -committerdate
[color]
  ui = auto
  diff = always
  grep = always
  branch = always
  status = always
  interactive = always
[alias]
  f   = fetch --prune --all
  p   = pull --prune
  st  = status
  sts = !"git status | awk '/On/,/Changes not staged/'"
  stn = !"git status | awk '/Changes not staged/,/END/'"
  br  = branch
  ci  = commit
  ck  = checkout
  cp  = cherry-pick
  wc  = whatchanged
  re  = remote -v
  dif = icdiff
  difc  = icdiff --cached
  diffc = diff --cached
  diffg = difftool --tool=vimdiff --no-prompt
  push  = push --tags
  pushf = push --force-with-lease
  url   = !git config --get remote.origin.url | sd '.git$' '' | sd ':' '/' | sd 'git@' 'https://'

  # log
  logp  = log -p
  logw  = log -p --word-diff=porcelain
  logs  = log --stat --pretty=format:'%C(yellow)commit %h%C(reset)%C(auto)%d%C(reset)%nAuthor: %an <%ae>%nDate:   %ad%n%n    %s%n' --date=format:'%Y-%m-%d %H:%M'
  logaa = log --graph --color --pretty='%x09%h %s %C(red)%d%C(reset)'
  loga = "!f() { \
    git log --graph --color=always --pretty='format:%x09%h [%G?|%an] %s %C(red)%d%C(reset)' --all \"$@\" | \
    sed -e 's/\\[G|\\([^]]*\\)\\]/\\x1b[32m[\\1]\\x1b[0m/g' \
        -e 's/\\[B|\\([^]]*\\)\\]/\\x1b[31m[\\1]\\x1b[0m/g' \
        -e 's/\\[U|\\([^]]*\\)\\]/\\x1b[33m[\\1]\\x1b[0m/g' \
        -e 's/\\[N|\\([^]]*\\)\\]/\\x1b[38;5;244m[\\1]\\x1b[0m/g' | \
    less -RFX; \
  }; f"
  logo  = log --graph --date=format:'%y-%m-%d(%a) %T' --pretty=format:'%C(green)%ad%C(reset) %an %ae %s'
  logg  = log --graph --date=format:'%y-%m-%d(%a) %T' --pretty=format:'%h %C(green)%cd %C(blue)%ad %C(green)%cn %C(blue)%an %C(green)%ce %C(blue)%ae %C(reset)%s'