[user]
  name = Jxck
  email = jxck@jxck.io
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMkUQk/n2TsfuVs13gBnm0ubTQ8SQToKF0k8vYJRR4qh
[gpg]
  format = ssh
[commit]
  gpgsign = true
[gpg "ssh"]
  allowedSignersFile = ~/dotfiles/.gitsigners
  # Linux では .gitconfig_local で "ssh-keygen" に上書き
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[init]
  defaultBranch = main # git init 時のデフォルトブランチ名を main にする
[http]
  cookiefile = ~/.gitcookies # HTTP 認証に使う Cookie ファイルのパス
[include]
  path = ~/.gitconfig_local # マシン固有の設定を別ファイルから読み込む
[core]
  editor = vim # コミットメッセージ等の編集に vim を使う
  pager = delta # delta をページャに使う
  autocrlf = input # コミット時に CRLF を LF に変換する
  fsmonitor = true # ワークツリーの変更検知を高速化する
  quotepath = false # 日本語ファイル名をエスケープせずそのまま表示する
  ignorecase = false # ファイル名の大文字小文字を区別する
  commitGraph = true # commit-graph ファイルを使って履歴の走査を高速化する
  untrackedCache = true # untracked ファイルのキャッシュを有効にして status を高速化する
  attributesfile = ~/.gitattributes # グローバルな gitattributes ファイルのパス
  excludesfile = ~/dotfiles/.gitignore_global # グローバルな gitignore ファイルのパス
[fetch]
  parallel = 0 # fetch 時の並列数を CPU コア数に自動(0)設定する
[pull]
  rebase = true # pull 時にマージコミットを作らず rebase する
[push]
  default = simple # 現在のブランチと同名のリモートブランチにのみ push する
  autoSetupRemote = true # push 時にリモート追跡ブランチを自動設定する
  useForceIfIncludes = true # force-with-lease 時にローカルの ref がリモートを含んでいるか検証する
[diff]
  algorithm = histogram # diff でより正確な差分を生成
  renameLimit = 9999 # リネーム検出の対象ファイル数上限を引き上げる
  compactionHeuristic = true # 空行を手がかりに diff のブロック境界を見やすくする
[merge]
  tool = vimdiff # vimdiff を使う
  keepBackup = false # バックアップファイル(.orig)を残さない
[mergetool]
  keepBackup = false # バックアップファイル(.orig)を残さない
[diff "png"]
  # 画像の diff をファイルサイズで比較
  textconv = gstat -c %s
[diff "gif"]
  # 画像の diff をファイルサイズで比較
  textconv = gstat -c %s
[diff "webp"]
  # 画像の diff をファイルサイズで比較
  textconv = gstat -c %s
[diff "jpeg"]
  # 画像の diff をファイルサイズで比較
  textconv = gstat -c %s
[interactive]
  diffFilter = delta --color-only # git add -p 等の対話操作で delta を使う
[delta]
  navigate = true # n/N で diff のファイル間をジャンプ
  line-numbers = true # 行番号を表示
  wrap-max-lines = 0 # 長い行を折り返さない (0=無制限)
  syntax-theme = Dracula # シンタックスハイライトのテーマ
  keep-plus-minus-markers = true # +/- マーカーを残す
  hunk-header-style = syntax # hunk ヘッダーをシンプルに
[column]
  ui = auto # branch や tag の一覧をカラム表示にする (自動判定)
[branch]
  sort = -committerdate # ブランチ一覧を最終コミット日時の降順で表示する
[color]
  ui = auto # 色付けを自動判定で有効にする
  diff = always
  grep = always
  branch = always
  status = always
  interactive = always
[alias]
  f   = fetch --prune --all
  p   = pull --prune
  st  = status
  sts = !"git status | awk '/On/,/Changes not staged/'"
  stn = !"git status | awk '/Changes not staged/,/END/'"
  br  = branch
  ci  = commit
  ck  = checkout
  cp  = cherry-pick
  wc  = whatchanged
  re  = rebase origin/main
  rem = remote -v
  dif = -c delta.side-by-side=true diff
  difc  = -c delta.side-by-side=true diff --cached
  diffc = diff --cached
  diffg = difftool --tool=vimdiff --no-prompt
  push  = push --tags
  pushf = push --force-with-lease
  url   = !git config --get remote.origin.url | sd '.git$' '' | sd ':' '/' | sd 'git@' 'https://'

  # log
  logp  = log -p
  logw  = log -p --word-diff=porcelain
  logs  = log --stat --pretty=format:'%C(yellow)commit %h%C(reset)%C(auto)%d%C(reset)%nAuthor: %an <%ae>%nDate:   %ad%n%n    %s%n' --date=format:'%Y-%m-%d %H:%M'
  logaa = log --graph --color --pretty='%x09%h %s %C(red)%d%C(reset)'
  loga = "!f() { \
    git log --graph --color=always --pretty='format:%x09%h [%G?|%an] %s %C(red)%d%C(reset)' --all \"$@\" | \
    sed -e 's/\\[G|\\([^]]*\\)\\]/\\x1b[32m[\\1]\\x1b[0m/g' \
        -e 's/\\[B|\\([^]]*\\)\\]/\\x1b[31m[\\1]\\x1b[0m/g' \
        -e 's/\\[U|\\([^]]*\\)\\]/\\x1b[33m[\\1]\\x1b[0m/g' \
        -e 's/\\[N|\\([^]]*\\)\\]/\\x1b[38;5;244m[\\1]\\x1b[0m/g' | \
    less -RFX; \
  }; f"
  logo  = log --graph --date=format:'%y-%m-%d(%a) %T' --pretty=format:'%C(green)%ad%C(reset) %an %ae %s'
  logg  = log --graph --date=format:'%y-%m-%d(%a) %T' --pretty=format:'%h %C(green)%cd %C(blue)%ad %C(green)%cn %C(blue)%an %C(green)%ce %C(blue)%ae %C(reset)%s'
