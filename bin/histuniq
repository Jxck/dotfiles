#!/usr/bin/env ruby

# ~/.zsh_history の重複除去/不要エントリ削除を行い圧縮

require "nkf"

filename = "#{ENV["HOME"]}/.zsh_history"
lines = []

# 複数行コマンド(末尾が \ の行)を結合してから処理する
raw_lines = []
buf = ""
File.foreach(filename) do |line|
  if buf.empty?
    buf = line
  else
    buf << line
  end
  if buf.end_with?("\\\n")
    next
  end
  raw_lines << buf
  buf = ""
end
raw_lines << buf unless buf.empty?

# フィルタリング: 不要なエントリを除外
raw_lines.each do |line|
  begin
    line.sub!(/^: \d+:\d+;/, '') # zsh extended history のタイムスタンプを除去
    line.strip!
    line.gsub!(/ +/, " ") # 連続スペースを正規化

    line.gsub!("\\n", "\n")          # 壊れた履歴のリテラル \n を実際の改行に戻す
    line = line.lines.last.strip      # 複数行になった場合は最後の行だけ残す

    next if line.empty?
    next if line.start_with?("cd ",
      "rm ",
      "\\rm ",
      "cp ",
      "calc ",
      "code ",
      "dc ",
      "diff-highlight ",
      "chmod ",
      "empty ",
      "file ",
      "fmt ",
      "format.rb ",
      "formatter.js ",
      "head ",
      "last ",
      "lint ",
      "ln ",
      "man ",
      "mkdir ",
      "mv ",
      "nodebrew ",
      "rails ",
      "rbenv ",
      "spacer ",
      "touch ",
      "unpack ",
      "pack ",
      "unpack ",
      "unzip ",
      "up ",
      "which ",
      "where ",
      "yarn ",
      "vim "
    ) # 使い捨てコマンドを除外
    next if line.size > 100          # 長すぎるコマンドを除外
    next if line.size < 14           # 短すぎるコマンドを除外
    next if line.count("'") % 2 == 1 # クォートが閉じていない壊れた行を除外
    next if line.count('"') % 2 == 1
    next if line.count("`") % 2 == 1

    if NKF.guess(line) == NKF::ASCII
      lines << line
    else
      puts "ignored: #{line}" # 非ASCII(日本語等)を含む行を除外
    end
  rescue
    puts "ignored: #{line}"
  end
end

# 重複除去
uniq_lines = lines.uniq

# D= で始まる環境変数設定は最新の1つだけ残す
blacklist = uniq_lines.select{|line|
  line.start_with?("D=")
}

filtered = uniq_lines - blacklist
filtered.unshift(blacklist.last) if blacklist.last

puts "log line: #{filtered.size}"

# 元ファイルとバックアップに書き出し
result = filtered.join("\n").concat("\n")

File.write(filename, result)
puts "#{filename} saved"
File.write(filename+".bk", result)
puts "#{filename}.bk saved"
