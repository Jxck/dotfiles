#!/usr/bin/env sh
os
echo $(vim --version | head -n 1 | cut -c 1-3,18-22 ; echo "https://github.com/vim/vim/releases"     )
echo $(tmux -V                                      ; echo "https://github.com/tmux/tmux/releases"   )
echo $(zsh --version             | cut -c 1-8       ; echo "http://zsh.sourceforge.net/releases.html")
echo node $(node --version                          ; echo "https://nodejs.org/ja/download/releases/")
echo $(ruby --version            | cut -c 1-10      ; echo "https://www.ruby-lang.org/ja/downloads/" )
echo $(git --version             | cut -c 1-4,13-20 ; echo "https://github.com/git/git/releases"     )
echo fzf $(fzf --version         | cut -c 1-7       ; echo "https://github.com/junegunn/fzf/releases")
